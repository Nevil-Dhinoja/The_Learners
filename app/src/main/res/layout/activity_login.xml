<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.LoginActivity"
    android:background="@drawable/login_page_bg">

    <TextView
        android:id="@+id/login_text"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="20dp"
        android:fontFamily="@font/montserrat"
        android:text="Sign-In and Never Lose Your Progress"
        android:textAlignment="center"
        android:textColor="@color/White"
        android:textSize="18sp"
        android:textStyle="bold" />

    <com.airbnb.lottie.LottieAnimationView
        android:layout_marginTop="90dp"
        android:layout_below="@id/login_text"
        android:id="@+id/login_lottie"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        app:lottie_rawRes="@raw/lottie_login"
        app:lottie_autoPlay="true"
        android:scaleType="centerCrop"
        app:lottie_loop="true"/>

    <TextView
        android:fontFamily="@font/montserrat"
        android:id="@+id/login_text2"
        android:layout_below="@id/login_lottie"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:text="One Tap Sign In"
        android:textColor="@color/Black"
        android:textSize="18sp"
        android:textAlignment="center"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="20dp"/>

    <androidx.cardview.widget.CardView
        android:layout_marginTop="20dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/login_text2"
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:cardCornerRadius="70dp">

        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/login_google"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_below="@+id/login_text2"
            android:layout_centerHorizontal="true"
            android:layout_gravity="center"
            android:background="@color/white"
            android:padding="20dp"
            android:src="@drawable/google_icon"
            app:riv_corner_radius="70dp" />
    </androidx.cardview.widget.CardView>


</RelativeLayout>