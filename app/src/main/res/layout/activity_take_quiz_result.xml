<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.TakeQuizResult"
    android:background="@color/Blue">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/result_close"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:layout_marginEnd="30dp"
        android:layout_marginTop="30dp"
        android:src="@drawable/close_icon"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/result_card"
        android:layout_below="@+id/result_close"
        android:layout_marginTop="50dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        android:background="@color/icon_bg"
        android:elevation="20dp">

        <LinearLayout
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@color/icon_bg">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/quiz_lottie"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:lottie_autoPlay="true"
                android:scaleType="fitCenter"
                app:lottie_loop="true"/>

            <TextView
                android:id="@+id/message1"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Congrats!"
                android:fontFamily="@font/montserrat"
                android:textColor="@color/Black"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <TextView
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz completed successfully."
                android:fontFamily="@font/montserrat"
                android:textColor="@color/Black"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/quiz_completed_currect"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correct : "
                android:fontFamily="@font/montserrat_medium"
                android:textColor="#21B600"
                android:textStyle="bold"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/quiz_completed_wrong"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wrong : "
                android:textColor="#940000"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat_medium"
                android:textSize="12sp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/score_less"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/result_card"
        android:layout_centerInParent="true"
        android:layout_marginTop="30dp"
        android:fontFamily="@font/montserrat"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

</RelativeLayout>