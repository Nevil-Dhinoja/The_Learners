<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:layout_marginBottom="20dp">

    <androidx.cardview.widget.CardView
        android:layout_gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginBottom="2dp"
        app:cardCornerRadius="20dp">

        <ImageView
            android:id="@+id/fitem_image"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="fitXY"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ui_ux_popular_courses"
            app:riv_corner_radius="140dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UI/UX Designing With Demo Example"
                android:id="@+id/fitem_text"
                android:textAlignment="center"
                android:layout_marginTop="190dp"
                android:layout_marginLeft="20dp"
                android:layout_marginBottom="5dp"
                android:fontFamily="@font/montserrat"
                android:textSize="14dp"
                android:textStyle="bold"
                android:textColor="@color/Black" />

            <TextView
                android:id="@+id/fitem_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:textColor="@color/Black"
                android:textStyle="bold"
                android:layout_marginLeft="20dp"
                android:text="UI/UX Design"
                android:textSize="10dp" />


                <ImageView
                    android:layout_marginTop="-30dp"
                    android:layout_gravity="end"
                    android:id="@+id/fitem"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="25dp"
                    android:layout_marginBottom="20dp"
                    android:src="@drawable/favourite_icon"/>


        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
