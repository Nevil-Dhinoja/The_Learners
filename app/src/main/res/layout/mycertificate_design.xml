<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/l1"
    android:gravity="center"
    android:layout_marginTop="20dp"
    android:layout_marginBottom="20dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/certificate_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                android:scaleType="fitXY"
                android:src="@drawable/certificate_background" />

            <LinearLayout
                android:layout_marginTop="30dp"
                android:layout_centerHorizontal="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/certificate"
                    android:textColor="@color/Blue"
                    android:textSize="23sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/of_completion"
                    android:textColor="@color/Blue"
                    android:textSize="10sp" />

                <TextView
                    android:layout_marginTop="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/presented_to"
                    android:textColor="@color/Black"
                    android:textStyle="bold"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="Krish Kalariya"
                    android:textColor="@color/Blue"
                    android:textSize="15sp" />

                <TextView
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/for_successfully"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/course_name"
                    android:layout_marginTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="Dhinoja Nevil"
                    android:textColor="@color/black"
                    android:textSize="13sp" />

                <TextView
                    android:layout_marginTop="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/provided_by"
                    android:textColor="@color/Black"
                    android:textStyle="bold"
                    android:textSize="10sp" />

                <TextView
                    android:layout_marginTop="3dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/the_learners"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="13sp" />

            </LinearLayout>

            <ImageView
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:layout_alignParentEnd="true"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/logo"/>

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_below="@id/certificate_card"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/download_btn"
            android:layout_margin="20dp"
            android:layout_width="110dp"
            android:layout_height="40dp"            android:background="@drawable/button_design"
            android:text="Download"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textColor="@color/White"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/share_btn"
            android:layout_margin="20dp"
            android:layout_width="110dp"
            android:layout_height="40dp"
            android:background="@drawable/button_design"
            android:text="Share"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textColor="@color/White"/>

    </LinearLayout>


</RelativeLayout>