<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Learning" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/Blue</item>
        <item name="colorPrimaryVariant">@color/Blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/Blue</item>
        <item name="colorSecondaryVariant">@color/Blue</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.Learning" parent="Theme.Design.Light">
        <item name="android:titleTextStyle">@style/MyActionBarTitle</item>
        <item name="colorControlNormal">@color/Blue</item>
        <item name="colorPrimary">@color/Blue</item>
        <item name="colorPrimaryDark">@color/Blue</item>
        <item name="colorAccent">@color/white</item>
    </style>

    <style name="MyActionBarTitle" parent="@android:style/TextAppearance.Holo.Widget.ActionBar.Title">
        <item name="android:textColor">#FFFFFF</item> <!-- White color code -->
        <item name="android:fontFamily">@font/montserrat</item>
    </style>


</resources>